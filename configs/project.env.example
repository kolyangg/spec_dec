# Copy to .env on the H100 server. Setup scripts auto-load .env when present.

# Python 3.12 is recommended by the homework for vLLM/quantization.
export PYTHON_BIN=python3.12

# Optional: override per environment if dependency resolution requires it.
# export SPECULATORS_PYTHON_BIN=python3.12
# export VLLM_PYTHON_BIN=python3.12
# export COMP_PYTHON_BIN=python3.12

# Optional: keep Hugging Face caches on a large local disk.
# export HF_HOME=/mnt/local/hf
# export TRANSFORMERS_CACHE=/mnt/local/hf/transformers
# export HF_DATASETS_CACHE=/mnt/local/hf/datasets

# Optional: required if model or dataset access needs authentication.
# export HF_TOKEN=hf_your_token_here

# Optional: override default venv/repo locations.
# export VENV_ROOT=/path/to/spec_dec/.venvs
# export EXTERNAL_DIR=/path/to/spec_dec/external
